# ── Build output ──────────────────────────────────────────
dist/
build/

# ── Astro generated types ────────────────────────────────
.astro/

# ── Dependencies ─────────────────────────────────────────
node_modules/

# ── Environment variables ────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ─────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
