Thumbs.db
ehthumbs.db
Desktop.ini

# ── TypeScript ───────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Testing / Coverage ───────────────────────────────────
coverage/
.nyc_output/

# ── Misc temporary files ─────────────────────────────────
.tmp/
tmp/
*.bak
