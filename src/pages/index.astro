---
import '../styles/global.css';
import { SaveEditor } from '../components/SaveEditor';
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>PokéClicker Save Editor - Modificateur de Sauvegarde Visuel & Complet</title>
		<meta name="description" content="Modifiez facilement votre sauvegarde PokéClicker. Éditeur visuel moderne pour Pokédollars, jetons de donjon, objets clés, objets d'Oak, Pokémon chromatiques (shiny), niveau souterrain et baies." />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
		
		<style>
			html, body {
				font-family: 'Outfit', sans-serif;
				background-color: #020617; /* bg-slate-950 */
			}
			code, pre, .font-mono {
				font-family: 'JetBrains Mono', monospace;
			}
		</style>
	</head>
	<body>
		<SaveEditor client:load />
	</body>
</html>

